# ─── Database (Render PostgreSQL) ────────────────────────────────────────────
# External Database URL from Render Dashboard
# Get from: Render Dashboard → PostgreSQL → External Database URL
DATABASE_URL=postgresql://username:password@hostname.render.com/database_name

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ─── Token Encryption (for GitHub OAuth tokens at rest) ──────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex chars (32 bytes)
ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_STRING

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Frontend (CORS) ──────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ─── GitHub OAuth (create at github.com/settings/developers) ─────────────────
# Leave blank until OAuth App is created
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# This MUST point to your backend callback route:
GITHUB_CALLBACK_URL=https://your-backend.onrender.com/api/v1/github/oauth/callback
